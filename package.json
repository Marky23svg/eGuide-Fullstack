{
  "name": "eguide-fullstack",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently --names \"SERVER,CLIENT\" --prefix-colors \"blue,green\" \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "npm --prefix server run dev",
    "dev:client": "npm --prefix frontend run dev",
    "install:all": "npm install && npm install --prefix server && npm install --prefix frontend"
  },
  "devDependencies": {
    "concurrently": "8.2.2",
    "shell-quote": "1.8.2"
  }
}
